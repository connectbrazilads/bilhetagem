DATABASE_URL=postgresql+psycopg://printbilling:printbilling@localhost:5432/printbilling
SECRET_KEY=replace-with-a-long-random-secret
CORS_ORIGINS=["http://localhost:3000"]
DEFAULT_MONTHLY_QUOTA=500
AUTO_CREATE_USERS=true
AUTO_CREATE_PRINTERS=true
SNMP_COMMUNITY=public
SNMP_TIMEOUT_SECONDS=2
SNMP_RETRIES=1
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=
INITIAL_AGENT_USERNAME=agent
INITIAL_AGENT_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@printbilling.local
SMTP_USE_TLS=true
MONTHLY_REPORT_EMAIL_SCHEDULER_ENABLED=true
MONTHLY_REPORT_EMAIL_SCHEDULER_INTERVAL_SECONDS=3600
